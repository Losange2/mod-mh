  "QuestText": {
    "QuestInfo": [
      {
        "Language": "JPN",
        "Name": "\u673D\u3061\u305F\u308B\u57CE\u306B\u3001\u738B\u306F\u7720\u308B",
        "Client": "\u30A8\u30EB\u30AC\u30C9\u89B3\u5149\u5354\u4F1A\u54E1",
        "Description": "\u30A8\u30EB\u30AC\u30C9\u89B3\u5149\u5354\u4F1A\u3067\u306F\u3001\u9AD8\u304F\u305D\u3073\r\n\u3048\u308B\u5C71\u3005\u3001\u6B74\u53F2\u60C5\u7DD2\u306E\u3042\u308B\u53E4\u57CE\u304C\r\n\u9B45\u529B\u7684\u306A\u57CE\u585E\u9AD8\u5730\u3092\u89B3\u5149\u540D\u6240\u3068\u3059\r\n\u308B\u30C4\u30A2\u30FC\u3092\u8A08\u753B\u4E2D\u3067\u3059\u3002\u3067\u3059\u304C\u3001\r\n\u30EA\u30AA\u30EC\u30A6\u30B9\u304C\u5C45\u5EA7\u3063\u3066\u304A\u308A\u3001\u53C2\u52A0\r\n\u8005\u306B\u5371\u967A\u304C\u53CA\u3093\u3067\u3057\u307E\u3044\u307E\u3059\u3002\r\n\u5B89\u5168\u306E\u305F\u3081\u72E9\u731F\u3092\u304A\u9858\u3044\u3057\u307E\u3059\u3002",
        "Target": "\u30EA\u30AA\u30EC\u30A6\u30B9\uFF11\u982D\u306E\u72E9\u731F",
        "Fail": "\u5831\u916C\u91D1\u30BC\u30ED\r\n\u30BF\u30A4\u30E0\u30A2\u30C3\u30D7"
      },
      {
        "Language": "ENG",
        "Name": "King of the Crumbling Castle",
        "Client": "Elgado Tourism Board Member",
        "Description": "We of the Tourism Board plan\r\nto make the towering mountains\r\nand charming architecture of the\r\nCitadel prime sightseeing spots.\r\nYet I fear the resident Rathalos\r\nwould make a poor addition to\r\nthe tour.",
        "Target": "Hunt a Rathalos",
        "Fail": "Reward hits 0, or time expires"
      },
      {
        "Language": "FRE",
        "Name": "Roi du ch\u00E2teau branlant",
        "Client": "Agent de tourisme d\u0027Elgado",
        "Description": "L\u0027office du tourisme aimerait\r\ntransformer les montagnes\r\net la belle architecture de la\r\nCitadelle en sites touristiques.\r\nToutefois, je doute que notre\r\nRathalos r\u00E9sident soit le bienvenu.",
        "Target": "Chasser un Rathalos",
        "Fail": "Prime \u00E0 0/Temps expir\u00E9"
      },
      {
        "Language": "ITA",
        "Name": "Re del castello fatiscente",
        "Client": "Membro pro loco Elgado",
        "Description": "Noi della pro loco vogliamo\r\nattirare i turisti verso le alte\r\nmontagne e la splendida\r\narchitettura della cittadella,\r\nma temo che i Rathalos non\r\nrenderebbero i tour piacevoli.",
        "Target": "Caccia un Rathalos",
        "Fail": "Premio a zero o tempo scaduto"
      },
      {
        "Language": "GER",
        "Name": "K\u00F6nig der br\u00F6ckelnden Burg",
        "Client": "Elgado-Tourismusmitarbeiter",
        "Description": "Wir vom Tourismusb\u00FCro wollen die\r\ngewaltigen Berge und reizende\r\nArchitektur der Zitadelle zu\r\nTop-Sehensw\u00FCrdigkeiten machen.\r\nAber der heimische Rathalos\r\nerg\u00E4nzt eine Sightseeing-Tour\r\nnur schlecht, f\u00FCrchte ich.",
        "Target": "Erjage einen Rathalos.",
        "Fail": "Belohnung auf 0 oder Zeit\r\nl\u00E4uft ab."
      },
      {
        "Language": "SPA",
        "Name": "El rey del castillo ruinoso",
        "Client": "Gu\u00EDa tur\u00EDstico de Elgado",
        "Description": "El consejo de turismo quiere\r\npromocionar las altas cumbres\r\ny la bella arquitectura del\r\nBasti\u00F3n. Lo malo es que hay un\r\nRathalos, \u00A1y nos va a espantar\r\na todos los turistas!",
        "Target": "Caza un Rathalos",
        "Fail": "La recompensa cae a 0\r\no se acaba el tiempo"
      },
      {
        "Language": "RUS",
        "Name": "\u041A\u043E\u0440\u043E\u043B\u044C \u0432\u0435\u0442\u0445\u043E\u0433\u043E \u0437\u0430\u043C\u043A\u0430",
        "Client": "\u0427\u043B\u0435\u043D \u042D\u043B\u0433\u0430\u0434. \u0441\u043E\u0432. \u043F\u043E \u0442\u0443\u0440\u0438\u0437\u043C\u0443",
