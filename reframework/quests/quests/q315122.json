      {
        "Language": "ENG",
        "Name": "The Good, the Bad, and Lagombi",
        "Client": "Linguistic Researcher",
        "Description": "Hunter, good... Lagombi, bad...\r\nWirebugs, good...\r\nSnowball, bad...\r\nBig ears, good...\r\nSonic Bomb, bad...\r\nMany bombs, good...\r\nForget bombs, bad...",
        "Target": "Hunt a Lagombi",
        "Fail": "Reward hits 0, or time expires"
      },
      {
        "Language": "FRE",
        "Name": "Le bon, la brute, et le Lagombi",
        "Client": "Chercheur linguistique",
        "Description": "Toi chasser Lagombi.\r\nLagombi jeter neige.\r\nNeige am\u00E9liorer jauge Filopt\u00E8re.\r\nDoucement, dangereux.\r\nLagombi, super oreilles.\r\nBoules de son, bonne id\u00E9e.\r\nToi en rapporter.",
        "Target": "Chasser un Lagombi",
        "Fail": "Prime \u00E0 0/Temps expir\u00E9"
      },
      {
        "Language": "ITA",
        "Name": "Lagombi, bianco",
        "Client": "Ricercatrice linguistica",
        "Description": "Mi servi, caccia un Lagombi.\r\nLagombi, tira palle di neve.\r\nDopo neve, barra insetto filo\r\npi\u00F9 carica. Lento, pericoloso.\r\nLagombi, ottimo udito. Usare\r\nbombe sonore, buona idea.\r\nPortane alcune, per favore.",
        "Target": "Caccia un Lagombi",
        "Fail": "Premio a zero o tempo scaduto"
      },
      {
        "Language": "GER",
        "Name": "Spiel mir das Lied vom Lagombi",
        "Client": "Sprachforscher",
        "Description": "J\u00E4ger, gut... Lagombi,\r\nschlecht... Seilk\u00E4fer, gut...\r\nSchneeball, schlecht...\r\nGro\u00DFe Ohren, gut...\r\nSchallbombe, schlecht...\r\nViele Bomben, gut...\r\nBomben vergessen, schlecht...",
        "Target": "Erjage einen Lagombi.",
        "Fail": "Belohnung auf 0 oder Zeit\r\nl\u00E4uft ab."
      },
      {
        "Language": "SPA",
        "Name": "El bueno, el feo y el Lagombi",
        "Client": "Investigadora ling\u00FCista",
        "Description": "\u003CLSNR {Cazador, bueno.} {Cazadora, buena.}\u003E Lagombi, malo.\r\nCord\u00F3pteros, buenos...\r\nBolas de nieve, malas...\r\nOrejas grandes, buenas...\r\nBomba s\u00F3nica, mala...\r\nMuchas bombas, bueno...\r\nOlvidarse bombas, malo...",
        "Target": "Caza un Lagombi",
        "Fail": "La recompensa cae a 0\r\no se acaba el tiempo"
