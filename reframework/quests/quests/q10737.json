        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0432\u044B\u0441\u0448\u0435\u0433\u043E \u041C\u0438\u0434\u0437\u0443\u0446\u0443\u043D\u044D",
