        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u041B\u0430\u0433\u043E\u043C\u0431\u0438, \u0411\u0430\u0440\u0438\u043E\u0442\u0430\r\n\u0438 \u0413\u043E\u0441\u0441-\u0425\u0430\u0440\u0430\u0433\u0430",
