        "Name": "\u9B3C\u706B",
        "Client": "\u30AE\u30EB\u30C9\u30DE\u30CD\u30FC\u30B8\u30E3\u30FC\u30FB\u30B4\u30B3\u30AF",
        "Description": "\u6028\u864E\u7ADC\u30DE\u30AC\u30A4\u30DE\u30AC\u30C9\u304C\u6EB6\u5CA9\u6D1E\u306B\r\n\u51FA\u305F\u3067\u30B2\u30B3\uFF01\u3000\u767E\u7ADC\u591C\u884C\u3092\u55B0\u3089\u3046\r\n\u3042\u3084\u3064\u304C\u3001\u3082\u3057\u3082\u91CC\u306E\u4ED8\u8FD1\u3067\r\n\u767E\u7ADC\u591C\u884C\u3068\u5408\u6D41\u3057\u3088\u3046\u3082\u306E\u306A\u3089\u3001\r\n\u4E00\u5927\u4E8B\uFF01\u3000\u305D\u3046\u306A\u3063\u3066\u3057\u307E\u3046\u524D\u306B\r\n\u306A\u3093\u3068\u3057\u3066\u3082\u9000\u6CBB\u3059\u308B\u3067\u30B2\u30B3\uFF01\r\n\u6025\u3050\u3067\u30B2\u30B3\u3088\uFF5E\uFF01",
