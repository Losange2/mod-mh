      {
        "Language": "JPN",
        "Name": "\u30E4\u30D6\u3092\u3064\u3064\u3044\u3066\u86EE\u984E\u7ADC\u3092\u51FA\u3059",
        "Client": "\u738B\u56FD\u9A0E\u58EB\u30D5\u30A3\u30AA\u30EC\u30FC\u30CD",
        "Description": "\u5358\u72EC\u3067\u6C34\u6CA1\u6797\u306B\u5411\u304B\u3063\u305F\u7ADC\u4EBA\u306E\r\n\u7814\u7A76\u54E1\u304C\u30A2\u30F3\u30B8\u30E3\u30CA\u30D5\u306E\u8972\u6483\u3092\r\n\u53D7\u3051\u3001\u623B\u3063\u3066\u3053\u3089\u308C\u306A\u304F\u306A\u3063\u305F\r\n\u3088\u3046\u3060\u3002\u81EA\u696D\u81EA\u5F97\u3060\u304C\u3001\u4EF2\u9593\u3092\r\n\u6368\u3066\u7F6E\u304F\u3053\u3068\u306F\u3067\u304D\u306A\u3044\u3002\r\n\u3053\u3061\u3089\u306E\u4E0D\u624B\u969B\u3067\u7533\u3057\u8A33\u306A\u3044\u304C\u3001\r\n\u5974\u306E\u6551\u51FA\u306B\u5411\u304B\u3063\u3066\u304F\u308C\u3002",
