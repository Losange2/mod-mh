        "Name": "\u041C\u0430\u043D\u044F\u0449\u0438\u0439 \u0441\u043E\u043D",
        "Client": "\u041E\u0431\u0435\u0441\u0441\u0438\u043B\u0435\u0432\u0448\u0430\u044F \u0436\u0435\u043D\u0449\u0438\u043D\u0430",
