      {
        "Language": "RUS",
        "Name": "\u0428\u043A\u0443\u0440\u043D\u044B\u0439 \u0432\u043E\u043F\u0440\u043E\u0441",
        "Client": "\u041C\u0430\u0441\u0442\u0435\u0440\u0438\u0446\u0430-\u043F\u043E\u0440\u0442\u043D\u0438\u0445\u0430",
        "Description": "\u0420\u0430\u0434\u043E\u0441\u0442\u044C \u043C\u043E\u044F, \u0442\u0443\u0442 \u043F\u0440\u0438\u0448\u0435\u043B \u043E\u0441\u043E\u0431\u044B\u0439\r\n\u0437\u0430\u043A\u0430\u0437 \u0434\u043B\u044F \u043E\u0441\u043E\u0431\u043E\u0433\u043E \u043A\u043B\u0438\u0435\u043D\u0442\u0430,\r\n\u0430 \u0443 \u043C\u0435\u043D\u044F \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B\u0438\u0441\u044C\r\n\u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B. \u0420\u0430\u0437\u0434\u043E\u0431\u0443\u0434\u0435\u0448\u044C \u0438\u0445 \u0434\u043B\u044F\r\n\u043C\u0435\u043D\u044F? \u041D\u0443\u0436\u043D\u044B \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u0430\u043C\u044B\u0435\r\n\u043B\u0443\u0447\u0448\u0438\u0435! \u041D\u0443 \u0436\u0435, \u0432\u043F\u0435\u0440\u0435\u0434!",
        "Target": "\u0423\u0431\u0438\u0442\u044C 20 \u043C\u043E\u043D\u0441\u0442\u0440\u043E\u0432 (\u042F\u0433\u0440\u0430\u0441\u043E\u0432 \u0438\u043B\u0438 \u041B\u0443\u0434\u0440\u043E\u0442\u043E\u0432)",
        "Fail": "\u0421\u0447\u0435\u0442\u0447\u0438\u043A \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0434\u043E\u0445\u043E\u0434\u0438\u0442 \u0434\u043E 0\r\n\u0438\u043B\u0438 \u0438\u0441\u0442\u0435\u043A\u0430\u0435\u0442 \u0432\u0440\u0435\u043C\u044F"
