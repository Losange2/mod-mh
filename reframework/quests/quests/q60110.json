        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0422\u0438\u0433\u0440\u0435\u043A\u0441\u0430 \u0438 \u0414\u0438\u0430\u0431\u043B\u043E\u0441\u0430",
