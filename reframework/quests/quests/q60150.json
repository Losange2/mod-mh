      {
        "Language": "RUS",
        "Name": "\u0412\u044B\u0441\u0448\u0438\u0439 \u0414\u0438\u0430\u0431\u043B\u043E\u0441, \u0441\u0440\u043E\u0447\u043D\u043E",
        "Client": "\u0418\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C \u041E\u0445. \u0413\u0438\u043B\u044C\u0434\u0438\u0438",
        "Description": "\u0421\u0440\u043E\u0447\u043D\u0430\u044F \u0434\u0435\u043F\u0435\u0448\u0430 \u043E\u0442 \u041E\u0445\u043E\u0442\u043D\u0438\u0447\u044C\u0435\u0439\r\n\u0413\u0438\u043B\u044C\u0434\u0438\u0438: \u0417\u0430\u043C\u0435\u0447\u0435\u043D \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439\r\n\u0432\u044B\u0441\u0448\u0438\u0439 \u043C\u043E\u043D\u0441\u0442\u0440, \u0441\u0440\u043E\u0447\u043D\u043E\r\n\u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0438\u0442\u044C! \u041E\u043D \u043E\u043F\u0430\u0441\u043D\u0435\u0435 \u043B\u044E\u0431\u043E\u0433\u043E\r\n\u0438\u0437 \u0440\u0430\u043D\u0435\u0435 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u0432\u0448\u0438\u0445\u0441\u044F \u0432\u044B\u0441\u0448\u0438\u0445.\r\n\u0415\u0441\u043B\u0438 \u0440\u0438\u0441\u043A \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0432\u044B\u0441\u043E\u043A \u2014\r\n\u043E\u0442\u0441\u0442\u0443\u043F\u0430\u0439\u0442\u0435.",
        "Target": "\u0423\u0431\u0438\u0442\u044C \u0432\u044B\u0441\u0448\u0435\u0433\u043E \u0414\u0438\u0430\u0431\u043B\u043E\u0441\u0430",
