      {
        "Language": "RUS",
        "Name": "\u0413\u0440\u043E\u043C\u043E\u0432\u043E\u0439 \u0433\u043E\u043B\u043E\u0441",
        "Client": "\u0411\u0435\u0433\u043B\u0435\u0446 \u0441 \u041C\u043E\u0440\u043E\u0437\u043D\u044B\u0445 \u043E\u0441\u0442\u0440\u043E\u0432\u043E\u0432",
