        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0432\u044B\u0441\u0448\u0435\u0433\u043E \u0420\u0430\u0442\u0430\u043B\u043E\u0441\u0430",
