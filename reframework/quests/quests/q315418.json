  "QuestText": {
    "QuestInfo": [
      {
        "Language": "JPN",
        "Name": "\u9ED2\u304D\u8863\u3092\u7E8F\u3046\u7ADC",
        "Client": "\u9ED2\u93A7\u3092\u307E\u3068\u3063\u305F\u72E9\u4EBA",
        "Description": "\u57CE\u585E\u9AD8\u5730\u306E\u3001\u9752\u304D\u7A7A\u306E\u4E0B\r\n\u9ED2\u304D\u8863\u3092\u8EAB\u306B\u7E8F\u3044\u3001\u82E6\u75DB\u306B\u8EAB\u3092\r\n\u3088\u3058\u308B\u8B0E\u306E\u7ADC\u3002\u898B\u3048\u3056\u308B\u8996\u7DDA\u3092\r\n\u8CB4\u69D8\u306B\u6CE8\u3050\u3002\r\n\u72E9\u308B\u5074\u3068\u72E9\u3089\u308C\u308B\u5074\u2026\u3002\r\n\u8CB4\u69D8\u306F\u3069\u3061\u3089\u3060\uFF1F",
        "Target": "\u30B4\u30A2\u30FB\u30DE\u30AC\u30E9\uFF11\u982D\u306E\u72E9\u731F",
        "Fail": "\u5831\u916C\u91D1\u30BC\u30ED\r\n\u30BF\u30A4\u30E0\u30A2\u30C3\u30D7"
      },
      {
        "Language": "ENG",
        "Name": "Dark Wings, Dark Work",
        "Client": "Black-Armored Hunter",
        "Description": "Beneath the azure skies of\r\nthe Citadel lurks a mysterious\r\nmonster cloaked in black.\r\nWrithing in pain, it glares\r\nfrom unseen eyes. The hunter\r\nor the hunted: which will\r\nyou be?",
        "Target": "Hunt a Gore Magala",
        "Fail": "Reward hits 0, or time expires"
      },
      {
        "Language": "FRE",
        "Name": "Noir comme la nuit",
        "Client": "Chasseur en armure noire",
        "Description": "Sous le ciel azur\r\nde la Citadelle r\u00F4de\r\nun monstre myst\u00E9rieux\r\ndrap\u00E9 de noir. Rong\u00E9 par\r\nla douleur, il observe sans\r\n\u00EAtre vu. Qui seras-tu :\r\nle chasseur ou la proie ?",
        "Target": "Chasser un Gore Magala",
        "Fail": "Prime \u00E0 0/Temps expir\u00E9"
      },
      {
        "Language": "ITA",
        "Name": "Ali oscure, oscuri lavori",
        "Client": "Cacciatore con corazza nera",
        "Description": "Nel cielo azzurro sopra la\r\ncittadella si nasconde un\r\nmostro tinto di nero. Si\r\ncontorce dal dolore e si cela\r\nagli occhi della gente. Sarai\r\nla preda o il cacciatore?",
        "Target": "Caccia un Gore Magala",
        "Fail": "Premio a zero o tempo scaduto"
      },
      {
        "Language": "GER",
        "Name": "Dunkle Fl\u00FCgel, dunkle Werke",
        "Client": "Schwarz ger\u00FCsteter J\u00E4ger",
        "Description": "Unter dem blauen Himmel der\r\nZitadelle lauert ein\r\ngeheimnisvolles Monster,\r\nin Schw\u00E4rze geh\u00FCllt.\r\nSeine Augen unsichtbar,\r\nseine Qualen sp\u00FCrbar. J\u00E4ger\r\noder Gejagter: Was bist du?",
        "Target": "Erjage einen Gore Magala.",
        "Fail": "Belohnung auf 0 oder Zeit\r\nl\u00E4uft ab."
      },
      {
        "Language": "SPA",
        "Name": "Alas negras como la noche",
        "Client": "Cazador con armadura negra",
        "Description": "Bajo los cielos azules del\r\nBasti\u00F3n acecha un misterioso\r\nmonstruo negro que se retuerce\r\nde dolor y nos esp\u00EDa sin que\r\nnadie lo vea. \u00BFSer\u00E1s quien lo\r\ncace o ser\u00E1s su presa?",
        "Target": "Caza un Gore Magala",
        "Fail": "La recompensa cae a 0\r\no se acaba el tiempo"
      },
      {
        "Language": "RUS",
        "Name": "\u0422\u0435\u043C\u043D\u044B\u0435 \u043A\u0440\u044B\u043B\u044C\u044F, \u0442\u0435\u043C\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430",
        "Client": "\u041E\u0445\u043E\u0442\u043D\u0438\u043A \u0432 \u0447\u0435\u0440\u043D\u043E\u0439 \u0431\u0440\u043E\u043D\u0435",
        "Description": "\u041F\u043E\u0434 \u043B\u0430\u0437\u0443\u0440\u043D\u044B\u043C\u0438 \u043D\u0435\u0431\u0435\u0441\u0430\u043C\u0438\r\n\u0426\u0438\u0442\u0430\u0434\u0435\u043B\u0438 \u0442\u0430\u0438\u0442\u0441\u044F \u0437\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u044B\u0439\r\n\u043C\u043E\u043D\u0441\u0442\u0440, \u043E\u043A\u0443\u0442\u0430\u043D\u043D\u044B\u0439 \u0442\u044C\u043C\u043E\u0439.\r\n\u041A\u043E\u0440\u0447\u0430\u0441\u044C \u043E\u0442 \u0431\u043E\u043B\u0438, \u043E\u043D \u0441\u043C\u043E\u0442\u0440\u0438\u0442\r\n\u043D\u0435\u0432\u0438\u0434\u0438\u043C\u044B\u043C\u0438 \u0433\u043B\u0430\u0437\u0430\u043C\u0438. \u041E\u0445\u043E\u0442\u043D\u0438\u043A\r\n\u0438\u043B\u0438 \u0434\u043E\u0431\u044B\u0447\u0430 \u2014 \u043A\u0435\u043C \u0431\u0443\u0434\u0435\u0448\u044C \u0442\u044B?",
        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u041A\u0440\u043E\u0432\u0430\u0432\u0443\u044E \u041C\u0430\u0433\u0430\u043B\u0443",
        "Fail": "\u0421\u0447\u0435\u0442\u0447\u0438\u043A \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0434\u043E\u0445\u043E\u0434\u0438\u0442 \u0434\u043E 0\r\n\u0438\u043B\u0438 \u0438\u0441\u0442\u0435\u043A\u0430\u0435\u0442 \u0432\u0440\u0435\u043C\u044F"
