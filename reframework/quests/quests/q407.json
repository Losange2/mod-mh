      {
        "Language": "RUS",
        "Name": "\u0421\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F \u0442\u0435\u043D\u044C",
        "Client": "\u041D\u0430\u0447\u0438\u043D\u0430\u044E\u0449\u0438\u0439 \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C",
        "Description": "\u042F \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u0417\u0430\u0442\u043E\u043F\u043B\u0435\u043D\u043D\u044B\u0439 \u043B\u0435\u0441, \u0438 \u0442\u0443\u0442\r\n\u0432\u043D\u0435\u0437\u0430\u043F\u043D\u043E \u0443\u0434\u0430\u0440\u0438\u043B\u0430 \u043C\u043E\u043B\u043D\u0438\u044F. \u042F \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u043B\r\n\u043D\u0430 \u043D\u0435\u0431\u043E \u2014 \u0442\u0430\u043C \u043A\u0442\u043E-\u0442\u043E \u043D\u043E\u0441\u0438\u043B\u0441\u044F,\r\n\u043F\u0443\u0441\u043A\u0430\u044F \u043C\u043E\u043B\u043D\u0438\u0438, \u0441 \u0434\u0435\u0440\u0435\u0432\u0430 \u043D\u0430 \u0434\u0435\u0440\u0435\u0432\u043E!\r\n\u0423\u0434\u0430\u043B\u043E\u0441\u044C \u0443\u0431\u0435\u0436\u0430\u0442\u044C, \u043D\u043E \u0434\u0440\u0443\u0433\u0438\u043C \u043C\u043E\u0436\u0435\u0442 \u0442\u0430\u043A\r\n\u043D\u0435 \u043F\u043E\u0432\u0435\u0437\u0442\u0438. \u041F\u0440\u043E\u0448\u0443, \u0441\u0434\u0435\u043B\u0430\u0439 \u0447\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C!",
        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0422\u043E\u0431\u0438-\u041A\u0430\u0434\u0430\u0447\u0438",
        "Fail": "\u0421\u0447\u0435\u0442\u0447\u0438\u043A \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0434\u043E\u0445\u043E\u0434\u0438\u0442 \u0434\u043E 0\r\n\u0438\u043B\u0438 \u0438\u0441\u0442\u0435\u043A\u0430\u0435\u0442 \u0432\u0440\u0435\u043C\u044F"
      },
      {
        "Language": "POL",
        "Name": "Przemykaj\u0105cy cie\u0144",
