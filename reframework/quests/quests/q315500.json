        "Name": "\u0421\u0435\u0439\u0441\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0443\u0433\u0440\u043E\u0437\u0430",
        "Client": "\u0422\u0430\u043A\u0442\u0438\u0447\u043D\u044B\u0439 \u043A\u043E\u0440\u043E\u043B. \u043A\u043E\u043C\u0435\u043D\u0434\u0430\u043D\u0442",
