      },
      {
        "Language": "POR",
        "Name": "Bishaten Faminto",
        "Client": "Fruteiro",
        "Description": "Estou procurando frutas na\r\nSelva, mas n\u00E3o encontro. Os\r\npelos azuis e marcas de\r\ncauda me dizem que \u00E9 coisa de\r\num Bishaten. Isso tem que\r\nacabar, ent\u00E3o quero que voc\u00EA\r\nme cace uma colheita melhor!",
        "Target": "Cace um Bishaten",
