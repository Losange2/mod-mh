      {
        "Language": "RUS",
        "Name": "\u041B\u044E\u0431\u043E\u0432\u044C \u043A \u043B\u0443\u043A\u0430\u043C",
        "Client": "\u041C\u0430\u0441\u0442\u0435\u0440 \u0423\u0446\u0443\u0441\u0438",
        "Description": "\u041D\u0443 \u0447\u0442\u043E, \u0430\u0441, \u043F\u043E\u0440\u0430 \u0443\u0447\u0438\u0442\u044C\u0441\u044F!\r\n\u0421\u043A\u043E\u0440\u043E\u0441\u0442\u044C, \u043B\u043E\u0432\u043A\u043E\u0441\u0442\u044C, \u0443\u043C\u0435\u043D\u0438\u0435\r\n\u0432\u044B\u0431\u0440\u0430\u0442\u044C \u043F\u043E\u0437\u0438\u0446\u0438\u044E \u2014 \u0432\u0441\u0435 \u044D\u0442\u043E\r\n\u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043D\u044B\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043A\u0438\r\n\u003CCOL RED\u003E\u0422\u043E\u0431\u0438-\u041A\u0430\u0434\u0430\u0447\u0438\u003C/COL\u003E. \u0417\u0430\u043C\u0435\u0442\u043D\u043E, \u043A\u0430\u043A \u043E\u043D\r\n\u043F\u043E\u0445\u043E\u0436 \u043D\u0430 \u0431\u043E\u0435\u0432\u043E\u0439 \u043B\u0443\u043A?\r\n\u0423\u0431\u0435\u0434\u0438\u0441\u044C \u043B\u0438\u0447\u043D\u043E!",
        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C 2 \u0422\u043E\u0431\u0438-\u041A\u0430\u0434\u0430\u0447\u0438",
        "Fail": "\u0421\u0447\u0435\u0442\u0447\u0438\u043A \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0434\u043E\u0445\u043E\u0434\u0438\u0442 \u0434\u043E 0\r\n\u0438\u043B\u0438 \u0438\u0441\u0442\u0435\u043A\u0430\u0435\u0442 \u0432\u0440\u0435\u043C\u044F"
