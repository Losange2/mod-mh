      {
        "Language": "JPN",
        "Name": "\u305F\u3060\u55B0\u3089\u3046\u767D\u304D\u5316\u751F",
        "Client": "\u8A69\u7684\u306B\u602F\u3048\u308B\u8A69\u4EBA",
