      },
      {
        "Language": "ITA",
        "Name": "La sfuggente stella del male",
        "Client": "Vecchia signora spaventata",
        "Description": "Il Valstrax \u00E8 tornato. Se vuoi\r\ndargli da caccia, fai\r\nattenzione alle sue ali: se\r\nnon ti bruciano, ti ridurranno\r\na un colino. Agisci in fretta e\r\nstai all\u0027erta. Tutto chiaro?\r\nBeh, buona fortuna!",
        "Target": "Uccidi un Valstrax cremisi",
        "Fail": "Premio a zero o tempo scaduto"
