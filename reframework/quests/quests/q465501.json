      {
        "Language": "RUS",
        "Name": "\u042F\u0440\u043E\u0441\u0442\u044C \u043A\u0430\u043A \u0441\u0442\u0438\u043C\u0443\u043B",
        "Client": "\u041C\u0430\u0441\u0442\u0435\u0440 \u0423\u0446\u0443\u0441\u0438",
        "Description": "\u0410\u0441! \u0422\u044B \u043A\u0430\u043A \u0440\u0430\u0437 \u0432\u043E\u0432\u0440\u0435\u043C\u044F!\r\n\u0412 \u0414\u0436\u0443\u043D\u0433\u043B\u044F\u0445 \u0437\u0430\u0432\u0435\u043B\u0441\u044F \u0420\u0430\u044F\u043D\u0433.\r\n\u041F\u043E\u043C\u043E\u0436\u0435\u0448\u044C \u0435\u0433\u043E \u0432\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C?\r\n\u041D\u0430\u0434\u043E \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u0432\u0441\u0435 \u0431\u044B\u0441\u0442\u0440\u043E...\r\n\u043D\u0430 \u0442\u043E \u0435\u0441\u0442\u044C \u0441\u0432\u043E\u0438 \u043F\u0440\u0438\u0447\u0438\u043D\u044B.\r\n\u041C\u044B \u043B\u0443\u0447\u0448\u0438\u0439 \u0434\u0443\u044D\u0442 \u043E\u0445\u043E\u0442\u043D\u0438\u043A\u043E\u0432!\r\n\u0414\u043B\u044F \u043D\u0430\u0441 \u044D\u0442\u043E \u2014 \u0440\u0430\u0437 \u043F\u043B\u044E\u043D\u0443\u0442\u044C!",
        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0420\u0430\u044F\u043D\u0433\u0430",
        "Fail": "\u0421\u0447\u0435\u0442\u0447\u0438\u043A \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0434\u043E\u0445\u043E\u0434\u0438\u0442 \u0434\u043E 0\r\n\u0438\u043B\u0438 \u0438\u0441\u0442\u0435\u043A\u0430\u0435\u0442 \u0432\u0440\u0435\u043C\u044F"
