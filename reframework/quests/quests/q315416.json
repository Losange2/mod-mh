        "Language": "KOR",
        "Name": "\uCDE8\uC625\uC758 \uC804\uB9C9, \uCCAD\uC625\uC758 \uACB8\uC870",
        "Client": "\uBBF8\uB97C \uCD94\uAD6C\uD558\uB294 \uBCF4\uC11D \uC7A5\uC778",
