      },
      {
        "Language": "GER",
        "Name": "Verd\u00E4chtiger Doppelg\u00E4nger",
        "Client": "Sorgloser Igel",
        "Description": "Ich dachte, der bl\u00F6de Doppel-\r\ng\u00E4nger w\u00FCrde mir wieder\r\nfolgen, aber es war etwas\r\nanderes. Das gef\u00E4llt mir gar\r\nnicht. Verjag das Ding, dann\r\nbesorg ich dir Materialien f\u00FCr\r\neine coole Dekorr\u00FCstung!",
        "Target": "Erjage einen Nargacuga.",
        "Fail": "Belohnung auf 0 oder Zeit\r\nl\u00E4uft ab."
      },
      {
        "Language": "SPA",
        "Name": "Acechador sombr\u00EDo",
