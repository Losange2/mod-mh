  "QuestText": {
    "QuestInfo": [
      {
        "Language": "JPN",
        "Name": "\u71C3\u3048\u3055\u304B\u308B\u65E5\u8F2A\u3088\u308A\u7D05\u304F",
        "Client": "\u7802\u539F\u306B\u4F4F\u307E\u3046\u53E4\u8001",
        "Description": "\u7802\u539F\u304B\u3089\u71B1\u304F\u7126\u3052\u305F\u98A8\u304C\u5439\u3044\u3066\u304A\r\n\u308B\u3002\u304B\u3064\u3066\u708E\u738B\u9F8D\u304C\u73FE\u308C\u3001\u6751\u3005\u3092\r\n\u706B\u306E\u6D77\u306B\u3057\u305F\u6642\u3068\u540C\u3058\u3058\u3083\u2026\u3002\r\n\u306F\u304F\u606F\u306F\u707C\u71B1\u3002\u8EAB\u306B\u307E\u3068\u3046\u708E\u306F\u3001\r\n\u3059\u3079\u3066\u3092\u898B\u5883\u306A\u304F\u713C\u304D\u5C3D\u304F\u3059\u2026\u3002\r\n\u72E9\u308A\u4EBA\u3088\u3001\u3044\u3084\u30CF\u30F3\u30BF\u30FC\u6BBF\u3001\r\n\u3069\u3046\u304B\u708E\u738B\u9F8D\u3092\u6B62\u3081\u3066\u304F\u3060\u3055\u308C\u3002",
        "Target": "\u30C6\u30AA\u30FB\u30C6\u30B9\u30AB\u30C8\u30EB\uFF11\u4F53\u306E\u8A0E\u4F10",
        "Fail": "\u5831\u916C\u91D1\u30BC\u30ED\r\n\u30BF\u30A4\u30E0\u30A2\u30C3\u30D7"
      },
      {
        "Language": "ENG",
        "Name": "Burn Brighter Than the Sun",
        "Client": "Desert Elder",
        "Description": "A hot, scorching wind blows\r\nfrom the Sandy Plains. The\r\nsame wind once felt from a\r\nTeostra, that turned the village\r\ninto a sea of flame. I beg\r\nyou Hunter, please stop\r\nthat wretched beast!",
        "Target": "Slay a Teostra",
        "Fail": "Reward hits 0, or time expires"
      },
      {
        "Language": "FRE",
        "Name": "Plus brillant que le soleil",
        "Client": "Ancien du d\u00E9sert",
        "Description": "Un vent br\u00FBlant souffle\r\ndes Plaines de sable. Le\r\nm\u00EAme que celui du Teostra qui\r\na fait br\u00FBler jadis tout\r\nle village. \u00C9limine ce monstre\r\ndangereux, je t\u0027en prie !",
        "Target": "Tuer un Teostra",
        "Fail": "Prime \u00E0 0/Temps expir\u00E9"
      },
      {
        "Language": "ITA",
        "Name": "Brucia pi\u00F9 del sole",
        "Client": "Anziano del deserto",
        "Description": "Un vento rovente soffia alle\r\nPiane sabbiose. Lo stesso soffio\r\ngenerato da un Teostra, che ha\r\ntrasformato il villaggio in un\r\nmare di fiamme. Ti prego,\r\nferma quella bestia abbietta!",
        "Target": "Uccidi un Teostra",
        "Fail": "Premio a zero o tempo scaduto"
      },
      {
        "Language": "GER",
        "Name": "Heller als die Sonne",
        "Client": "W\u00FCsten\u00E4ltester",
        "Description": "Von der Sandebene weht ein heis-\r\nser, brennender Wind. Der glei-\r\nche, der von einem Teostra zu\r\nsp\u00FCren war, der das Dorf in ein\r\nFlammenmeer verwandelte. Ich\r\nflehe dich an, bitte halte diese\r\nverfluchte Bestie auf.",
        "Target": "Erlege einen Teostra.",
        "Fail": "Belohnung auf 0 oder Zeit\r\nl\u00E4uft ab."
      },
      {
        "Language": "SPA",
        "Name": "M\u00E1s brillo que el sol",
        "Client": "Anciano del desierto",
        "Description": "Un viento sofocante llega de\r\nlos Llanos arenosos, el mismo\r\nque una vez trajo un Teostra,\r\nque torn\u00F3 la aldea en un mar\r\nde fuego. \u00A1Det\u00E9n a esa bestia\r\nhorripilante, te lo ruego!",
        "Target": "Abate un Teostra",
        "Fail": "La recompensa cae a 0\r\no se acaba el tiempo"
      },
      {
        "Language": "RUS",
        "Name": "\u0413\u043E\u0440\u0438 \u044F\u0440\u0447\u0435 \u0441\u043E\u043B\u043D\u0446\u0430",
        "Client": "\u041F\u0443\u0441\u0442\u044B\u043D\u043D\u044B\u0439 \u0434\u0440\u0435\u0432\u043D\u0438\u0439",
