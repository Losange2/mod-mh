  "QuestText": {
    "QuestInfo": [
      {
        "Language": "JPN",
        "Name": "\u53EF\u53CA\u7684\u901F\u3084\u304B\u306B\u72E9\u731F\u3092",
        "Client": "\u771F\u9762\u76EE\u306A\u8ABF\u67FB\u968A\u54E1",
        "Description": "\u79C1\u306F\u3001\u306F\u308B\u3070\u308B\u6D77\u3092\u6E21\u308A\u8D74\u4EFB\u3057\u305F\r\n\u8ABF\u67FB\u968A\u54E1\u3067\u3059\u3002\u304A\u898B\u77E5\u308A\u304A\u304D\u3092\u3002\r\n\u3064\u304D\u307E\u3057\u3066\u306F\u5F53\u5730\u306E\u30E2\u30F3\u30B9\u30BF\u30FC\u306E\r\n\u8ABF\u67FB\u306E\u305F\u3081\u3001\u30AF\u30EB\u30EB\u30E4\u30C3\u30AF\u306E\r\n\u72E9\u731F\u3092\u4F9D\u983C\u3057\u307E\u3059\u3002\u65E9\u304F\u3053\u306E\u89B3\u6E2C\r\n\u62E0\u70B9\u306B\u6163\u308C\u3066\u6210\u679C\u3092\u4E0A\u3052\u306D\u3070\r\n\u306A\u308A\u307E\u305B\u3093\u3002\u3088\u308D\u3057\u304F\u3069\u3046\u305E\u3002",
        "Target": "\u30AF\u30EB\u30EB\u30E4\u30C3\u30AF\uFF11\u982D\u306E\u72E9\u731F",
        "Fail": "\u5831\u916C\u91D1\u30BC\u30ED\r\n\u30BF\u30A4\u30E0\u30A2\u30C3\u30D7"
      },
      {
        "Language": "ENG",
        "Name": "Need a Hunter, ASAP!",
        "Client": "Serious Researcher",
        "Description": "Yes, yes. Greetings. Now if you\r\ndon\u0027t mind, I didn\u0027t come all this\r\nway for formalities. I came here\r\nto research monsters. And I intend\r\nto do just that! I require that you\r\nhunt a Kulu-Ya-Ku immediately.\r\nWell... What are you waiting for?",
        "Target": "Hunt a Kulu-Ya-Ku",
        "Fail": "Reward hits 0, or time expires"
      },
      {
        "Language": "FRE",
        "Name": "Chasseur demand\u00E9 !",
        "Client": "Chercheur s\u00E9rieux",
        "Description": "Je suis chercheur et je viens\r\nde loin pour \u00E9tudier les monstres\r\nqui vivent ici.\r\nJ\u0027aimerais commencer\r\npar un Kulu-Ya-Ku.\r\n\u00C0 toi d\u0027en chasser un\r\net de me le rapporter !",
        "Target": "Chasser un Kulu-Ya-Ku",
        "Fail": "Prime \u00E0 0/Temps expir\u00E9"
      },
      {
        "Language": "ITA",
        "Name": "Un cacciatore, presto!",
        "Client": "Ricercatore serio",
        "Description": "Sono un ricercatore venuto da\r\noltre il mare per indagare sui\r\nmostri presenti qui. Per prima\r\ncosa, ti chiedo di cacciare un\r\nKulu-Ya-Ku. Devo abituarmi\r\nin fretta all\u0027avamposto, quindi\r\nfai presto.",
        "Target": "Caccia un Kulu-Ya-Ku",
        "Fail": "Premio a zero o tempo scaduto"
      },
      {
        "Language": "GER",
        "Name": "Schnellstm\u00F6glich J\u00E4ger gesucht",
        "Client": "Ernstzunehmender Forscher",
        "Description": "Ja, ja. Gr\u00FC\u00DFe. Wenn es dir\r\nnichts ausmacht, \u00FCberspringe\r\nich die Formalit\u00E4ten. Ich bin\r\nhier, um Monster zu erforschen.\r\nErjage mir sofort einen Kulu-\r\nYa-Ku! ... Los, mach schon!\r\nWorauf wartest du noch?",
        "Target": "Erjage einen Kulu-Ya-Ku.",
        "Fail": "Belohnung auf 0 oder Zeit\r\nl\u00E4uft ab."
      },
      {
        "Language": "SPA",
        "Name": "Necesito un cazador, \u00A1ya!",
        "Client": "Investigador serio",
        "Description": "S\u00ED, s\u00ED. Saludos. Ahora, si no te\r\nimporta, no he venido hasta aqu\u00ED\r\npara formalidades, sino para\r\ncazar a monstruos. \u00A1Y eso har\u00E9!\r\nNecesito que caces a un\r\nKulu-Ya-Ku inmediatamente, as\u00ED\r\nque... \u00BFa qu\u00E9 est\u00E1s esperando?",
        "Target": "Caza un Kulu-Ya-Ku",
        "Fail": "La recompensa cae a 0\r\no se acaba el tiempo"
      },
      {
        "Language": "RUS",
        "Name": "\u0418\u0449\u0443 \u043E\u0445\u043E\u0442\u043D\u0438\u043A\u0430. \u0421\u0440\u043E\u0447\u043D\u043E!",
        "Client": "\u0421\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u0439 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C",
        "Description": "\u042F \u2014 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C, \u043F\u0435\u0440\u0435\u043F\u043B\u044B\u0432\u0448\u0438\u0439\r\n\u043C\u043E\u0440\u0435 \u0440\u0430\u0434\u0438 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F \u043C\u0435\u0441\u0442\u043D\u044B\u0445\r\n\u043C\u043E\u043D\u0441\u0442\u0440\u043E\u0432. \u0414\u043B\u044F \u043D\u0430\u0447\u0430\u043B\u0430 \u043F\u0440\u043E\u0448\u0443\r\n\u0442\u0435\u0431\u044F \u0432\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u041A\u0443\u043B\u0443-\u0419\u0430-\u041A\u0443.\r\n\u041C\u043D\u0435 \u043D\u0443\u0436\u043D\u043E \u0431\u044B\u0441\u0442\u0440\u043E \u043F\u0440\u0438\u0432\u044B\u043A\u043D\u0443\u0442\u044C\r\n\u043A \u044D\u0442\u043E\u043C\u0443 \u0430\u0432\u0430\u043D\u043F\u043E\u0441\u0442\u0443, \u0442\u0430\u043A \u0447\u0442\u043E\r\n\u043F\u043E\u0441\u043F\u0435\u0448\u0438!",
        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u041A\u0443\u043B\u0443-\u0419\u0430-\u041A\u0443",
        "Fail": "\u0421\u0447\u0435\u0442\u0447\u0438\u043A \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0434\u043E\u0445\u043E\u0434\u0438\u0442 \u0434\u043E 0\r\n\u0438\u043B\u0438 \u0438\u0441\u0442\u0435\u043A\u0430\u0435\u0442 \u0432\u0440\u0435\u043C\u044F"
