        "Language": "JPN",
        "Name": "\u7802\u539F\u306E\u9B54\u7403\u306B\u3054\u6CE8\u610F\u3092",
        "Client": "\u4E0D\u904B\u306A\u884C\u5546\u4EBA",
        "Description": "\u3042\u3042\u3041\u2026\u672C\u5F53\u306B\u3064\u3044\u3066\u306A\u3044\u308F\u2026\u3002\r\n\u30E9\u30F3\u30B0\u30ED\u30C8\u30E9\uFF12\u982D\u306B\u8FFD\u3044\u56DE\u3055\u308C\u3066\r\n\u3042\u3061\u3053\u3061\u9003\u3052\u56DE\u3063\u3066\u3044\u308B\u3046\u3061\u306B\u3001\r\n\u305B\u3063\u304B\u304F\u306E\u65B0\u9BAE\u306A\u98DF\u6750\u304C\u50B7\u3093\u3067\r\n\u3057\u307E\u3063\u305F\u3093\u3067\u3059\u2026\u3002\r\n\u6B21\u306F\u79C1\u304C\u50B7\u3064\u3051\u3089\u308C\u306A\u3044\u3088\u3046\u306B\u3001\r\n\u72E9\u731F\u3092\u304A\u9858\u3044\u81F4\u3057\u307E\u3059\u2026\u3002",
        "Target": "\u30E9\u30F3\u30B0\u30ED\u30C8\u30E9\uFF12\u982D\u306E\u72E9\u731F",
