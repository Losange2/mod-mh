        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u041A\u0435\u0437\u0443 \u0438 \u0420\u0430\u043A\u043D\u0430-\u041A\u0430\u0434\u0430\u043A\u0438",
