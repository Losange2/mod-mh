        "Name": "\u0413\u0443\u0431\u0447\u0430\u0442\u044B\u0439 \u043E\u0430\u0437\u0438\u0441",
        "Client": "\u041F\u0443\u0441\u0442\u044B\u043D\u043D\u044B\u0439 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u044C",
