      {
        "Language": "JPN",
        "Name": "\u51CD\u3048\u308B\u6D77\u304B\u3089\u624B\u62DB\u304F\u3082\u306E",
        "Client": "\u7814\u7A76\u54E1\u30D0\u30CF\u30EA",
        "Description": "\u3055\u3063\u304D\u53E3\u982D\u3067\u4F1D\u3048\u305F\u8A71\u3092\u4F9D\u983C\u6587\u3067\r\n\u307E\u305F\u66F8\u304F\u3063\u3066\u306E\u3082\u9762\u5012\u3060\u306A\u3042\u2026\u3002\r\n\u307E\u3001\u3044\u3044\u3084\u3002\u30AD\u30DF\u306B\u983C\u307F\u305F\u3044\u306E\u306F\r\n\u30A4\u30BD\u30CD\u30DF\u30AF\u30CB\u4E9C\u7A2E\u306E\u72E9\u731F\u3060\u3002\u4F8B\u306E\r\n\u751F\u7269\u306E\u6355\u7372\u306F\u4FFA\u304C\u62C5\u5F53\u3059\u308B\u304B\u3089\r\n\u30AD\u30DF\u306B\u306F\u5B89\u5168\u78BA\u4FDD\u3092\u304A\u9858\u3044\u3057\u305F\u3044\r\n\u3063\u3066\u308F\u3051\u3002\u305D\u308C\u3058\u3083\u3088\u308D\u3057\u304F\uFF01",
        "Target": "\u30A4\u30BD\u30CD\u30DF\u30AF\u30CB\u4E9C\u7A2E\uFF11\u982D\u306E\u72E9\u731F",
