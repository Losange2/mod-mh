        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0421\u0435\u0440\u0435\u0433\u0438\u043E\u0441\u0430 \u0438 \u0413\u0430\u0440\u0430\u043D\u0433\u043E\u043B\u044C\u043C\u0430",
