      {
        "Language": "JPN",
        "Name": "\u5BC6\u6797\u306E\u30DD\u30A4\u30BA\u30F3\u30AB\u30FC\u30DA\u30C3\u30C8",
        "Client": "\u56DE\u308A\u304F\u3069\u3044\u9ED2\u670D\u306E\u7537\u6027",
        "Description": "\u3068\u3042\u308B\u8981\u4EBA\u304C\u62E0\u70B9\u3092\u30D3\u30B8\u30C3\u30C8\u304B\u3064\r\n\u8A2A\u554F\u3059\u308B\u4E88\u5B9A\u306A\u306E\u3067\u3059\u304C\u3001\r\n\u305D\u306E\u30EB\u30FC\u30C8\u304B\u3064\u901A\u308A\u9053\u306E\u5BC6\u6797\u306B\r\n\u30C9\u30B9\u30D5\u30ED\u30AE\u30A3\u304C\uFF12\u982D\u51FA\u73FE\u3057\u305F\u3068\r\n\u5831\u544A\u304C\u5165\u308A\u307E\u3057\u305F\u3002\u4E07\u4E00\u304C\u3042\u3063\u3066\r\n\u306F\u3044\u3051\u307E\u305B\u3093\u3002\u30D9\u30EA\u30FC\u30B9\u30DE\u30FC\u30C8\u304B\r\n\u3064\u8FC5\u901F\u4E01\u5BE7\u306A\u72E9\u731F\u3092\u9858\u3044\u307E\u3059\u3088\u3002",
