      {
        "Language": "JPN",
        "Name": "\u6025\u3044\u3066\u306F\u718A\u3092\u4ED5\u640D\u3058\u308B",
        "Client": "\u52A0\u5DE5\u5C4B\u306E\u30CF\u30E2\u30F3",
