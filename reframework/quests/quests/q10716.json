        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0413\u043E\u0441\u0441-\u0425\u0430\u0440\u0430\u0433\u0430 \u0438 \u0422\u0435\u0442\u0440\u0430\u043D\u0430\u0434\u043E\u043D\u0430",
