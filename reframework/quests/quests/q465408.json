      {
        "Language": "RUS",
        "Name": "\u0414\u0443\u044D\u0442 \u0443\u0447\u0438\u0442\u0435\u043B\u044F \u0438 \u0443\u0447\u0435\u043D\u0438\u043A\u0430",
        "Client": "\u041C\u0430\u0441\u0442\u0435\u0440 \u0423\u0446\u0443\u0441\u0438",
        "Description": "\u041F\u0440\u0438\u0432\u0435\u0442, \u0430\u0441! \u0421\u0440\u0430\u0437\u0443 \u043A \u0434\u0435\u043B\u0443 \u2014\r\n\u043F\u043E\u0440\u0430 \u0432\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0417\u0438\u043D\u043E\u0433\u0440\u0430!\r\n\u0414\u0430\u0432\u043D\u043E \u043C\u044B \u043D\u0435 \u043E\u0445\u043E\u0442\u0438\u043B\u0438\u0441\u044C \u0432\u043C\u0435\u0441\u0442\u0435,\r\n\u0438 \u0441\u0435\u0439\u0447\u0430\u0441 \u043C\u043D\u0435 \u0431\u0435\u0437 \u0442\u0435\u0431\u044F\r\n\u043D\u0435 \u043E\u0431\u043E\u0439\u0442\u0438\u0441\u044C. \u041F\u043E\u043A\u0430\u0436\u0438, \u0447\u0435\u043C\u0443 \u0442\u044B\r\n\u003CLSNR {\u043D\u0430\u0443\u0447\u0438\u043B\u0441\u044F} {\u043D\u0430\u0443\u0447\u0438\u043B\u0430\u0441\u044C}\u003E \u0432 \u042D\u043B\u0433\u0430\u0434\u043E!",
        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0417\u0438\u043D\u043E\u0433\u0440\u0430",
        "Fail": "\u0421\u0447\u0435\u0442\u0447\u0438\u043A \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0434\u043E\u0445\u043E\u0434\u0438\u0442 \u0434\u043E 0\r\n\u0438\u043B\u0438 \u0438\u0441\u0442\u0435\u043A\u0430\u0435\u0442 \u0432\u0440\u0435\u043C\u044F"
