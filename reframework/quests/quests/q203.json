      {
        "Language": "JPN",
        "Name": "\u98DF\u3079\u76DB\u308A\u306E\u9752\u718A\u7363",
        "Client": "\u91CC\u4E00\u756A\u306E\u91E3\u308A\u540D\u4EBA",
        "Description": "\u3044\u3084\uFF5E\u53C2\u3063\u305F\u3002\u3042\u3042\u3082\u898B\u5883\u306A\u304F\r\n\u9B5A\u3092\u98DF\u3079\u7D9A\u3051\u3089\u308C\u308B\u3068\u3001\u91CC\u306B\r\n\u6301\u3061\u5E30\u308B\u5206\u306E\u9B5A\u304C\u53D6\u308C\u306A\u304F\u306A\u308B\r\n\u3069\u3053\u308D\u304B\u3001\u9B5A\u304C\u4E00\u5339\u3082\u3044\u306A\u304F\r\n\u306A\u3063\u3061\u307E\u3046\u3088\u3002\r\n\u5DDD\u304B\u3089\u9B5A\u304C\u6D88\u3048\u3061\u307E\u3046\u524D\u306B\r\n\u30A2\u30A4\u30C4\u3092\u9000\u6CBB\u3057\u3066\u304F\u308C\u306A\u3044\u304B\uFF1F",
        "Target": "\u30A2\u30AA\u30A2\u30B7\u30E9\uFF11\u982D\u306E\u72E9\u731F",
