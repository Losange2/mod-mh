      {
        "Language": "RUS",
        "Name": "\u0410\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u0430\u044F \u0441\u0438\u043B\u0430",
        "Client": "\u0421\u0435\u0432\u0435\u0440\u043D\u044B\u0435 \u0441\u043F\u0430\u0441\u0430\u0442\u0435\u043B\u0438",
        "Description": "\u041C\u044B \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438 \u0441\u0438\u0433\u043D\u0430\u043B S.O.S. \u043E\u0442\r\n\u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u0447\u043B\u0435\u043D\u043E\u0432 \u044D\u043A\u043E-\u0433\u0440\u0443\u043F\u043F\u044B,\r\n\u0437\u0430\u0441\u0442\u0440\u044F\u0432\u0448\u0438\u0445 \u0432 \u0433\u043E\u0440\u0430\u0445. \u0422\u0430\u043C \u0431\u0443\u0448\u0443\u0435\u0442\r\n\u0422\u0438\u0433\u0440\u0435\u043A\u0441, \u0438 \u043E\u043D\u0438 \u043D\u0435 \u043C\u043E\u0433\u0443\u0442\r\n\u0441\u043F\u0443\u0441\u0442\u0438\u0442\u044C\u0441\u044F. \u0421\u0430\u043C\u0438 \u043C\u044B \u0441 \u043D\u0438\u043C\r\n\u0441\u043F\u0440\u0430\u0432\u0438\u0442\u044C\u0441\u044F \u043D\u0435 \u0441\u0443\u043C\u0435\u0435\u043C. \u041F\u0440\u043E\u0448\u0443,\r\n\u0438\u0437\u0431\u0430\u0432\u044C\u0441\u044F \u043E\u0442 \u0422\u0438\u0433\u0440\u0435\u043A\u0441\u0430!",
        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0422\u0438\u0433\u0440\u0435\u043A\u0441\u0430",
        "Fail": "\u0421\u0447\u0435\u0442\u0447\u0438\u043A \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0434\u043E\u0445\u043E\u0434\u0438\u0442 \u0434\u043E 0\r\n\u0438\u043B\u0438 \u0438\u0441\u0442\u0435\u043A\u0430\u0435\u0442 \u0432\u0440\u0435\u043C\u044F"
      },
      {
