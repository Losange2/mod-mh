        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u041F\u043E\u043A\u0438-\u041F\u043E\u043A\u0438 \u0438 \u0411\u0430\u0440\u0440\u043E\u0442\u0430",
