      {
        "Language": "JPN",
        "Name": "\u6708\u591C\u306B\u307E\u3069\u308D\u3080\u7720\u308A\u7ADC",
        "Client": "\u30A2\u30EB\u30ED\u30FC\u6559\u5B98",
        "Description": "\u3088\u3046\u3002\u307E\u305F\u3057\u3066\u3082\u3053\u306E\u4FFA\u3001\r\n\u30A2\u30EB\u30ED\u30FC\u6559\u5B98\u304B\u3089\u306E\u304A\u8A98\u3044\u3060\u305C\u3002\r\n\u30A8\u30B9\u30D4\u30CA\u30B9\u304C\u57CE\u585E\u9AD8\u5730\u3067\u66B4\u308C\u3066\r\n\u3044\u308B\u3089\u3057\u304F\u3066\u306A\u3001\u591C\u306B\u72E9\u731F\u306B\r\n\u884C\u304F\u3064\u3082\u308A\u3060\u3002\u5831\u916C\u3082\u3061\u3083\u3093\u3068\r\n\u51FA\u308B\u304B\u3089\u3088\u3001\u3061\u3087\u3063\u304F\u3089\u8001\u3044\u307C\u308C\r\n\u306E\u72E9\u731F\u306B\u4ED8\u304D\u5408\u3063\u3066\u304F\u308C\u3084\u3002",
