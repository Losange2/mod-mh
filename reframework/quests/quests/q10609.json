      {
        "Language": "ARA",
        "Name": "\u0627\u0644\u0647\u0627\u0648\u064A\u0629 \u062A\u062D\u062F\u0651\u0642 \u003CLSNR {\u0625\u0644\u064A\u0643} {\u0625\u0644\u064A\u0643\u0650}\u003E",
        "Client": "\u0627\u0644\u0635\u064A\u0651\u0627\u062F \u0627\u0644\u0645\u0635\u062F\u0648\u0645",
        "Description": "\u0645\u0627 \u0632\u0644\u062A \u0623\u0631\u0627\u0647. \u062D\u062A\u0649 \u0627\u0644\u0622\u0646 \u0639\u0646\u062F\u0645\u0627\r\n\u0623\u063A\u0645\u0636 \u0639\u064A\u0646\u064A. \u0641\u0631\u0627\u063A \u0645\u062A\u0646\u0642\u0644. \u0623\u062D\u0644\u0643\r\n\u0638\u0644\u0627\u0645 \u064A\u0645\u0643\u0646 \u0623\u0646 \u003CLSNR {\u062A\u062A\u062E\u064A\u0644\u0647} {\u062A\u062A\u062E\u064A\u0644\u064A\u0647}\u003E. \u0644\u0646\r\n\u003CLSNR {\u062A\u0639\u0631\u0641} {\u062A\u0639\u0631\u0641\u064A}\u003E \u0623\u0646\u0647 \u0647\u0646\u0627\u0643 \u062D\u062A\u0649 \u0641\u0648\u0627\u062A\r\n\u0627\u0644\u0623\u0648\u0627\u0646. \u0645\u0646 \u0647\u0627\u0648\u064A\u0629 \u0627\u0644\u0644\u064A\u0644\u060C \u064A\u0646\u062F\u0641\u0639\r\n\u0634\u0639\u0627\u0639\u0627\u0646 \u062D\u0645\u0631\u0627\u0648\u0627\u0646 \u003CLSNR {\u0646\u062D\u0648\u0643} {\u0646\u062D\u0648\u0643\u0650}\u003E. \u003CLSNR {\u064A\u0647\u0627\u062C\u0645\u0627\u0646\u0643} {\u064A\u0647\u0627\u062C\u0645\u0627\u0646\u0643\u0650}\u003E\r\n\u0642\u0628\u0644 \u0623\u0646 \u003CLSNR {\u062A\u062A\u0645\u0643\u0646} {\u062A\u062A\u0645\u0643\u0646\u064A}\u003E \u062D\u062A\u0649 \u0645\u0646 \u0627\u0644\u0631\u062F.",
        "Target": "\u0635\u064A\u062F \u0646\u0627\u0631\u062C\u0627\u0643\u0648\u062C\u0627",
        "Fail": "0 \u0636\u0631\u0628\u0627\u062A \u0627\u0644\u0645\u0643\u0627\u0641\u0623\u0629\u060C \u0623\u0648 \u064A\u0646\u0641\u062F \u0627\u0644\u0648\u0642\u062A"
