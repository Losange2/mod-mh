      },
      {
        "Language": "ZHT",
        "Name": "\u5283\u7834\u9ED1\u591C\u7684\u8D64\u7D05\u96D9\u7738",
        "Client": "\u5687\u5F97\u767C\u6296\u7684\u7375\u4EBA",
        "Description": "\u6211\u770B\u898B\u5B9B\u5982\u8981\u6495\u88C2\u9ED1\u591C\u7684\r\n\u8D64\u7D05\u5149\u8292\u903C\u8FD1\u773C\u524D\uFF0C\u7136\u5F8C\u2026\u2026\r\n\u7728\u773C\u4E4B\u9593\uFF0C\u6211\u548C\u5925\u4F34\u5011\r\n\u5C31\u5168\u90FD\u88AB\u6253\u5012\u5728\u5730\u4E86\u3002\r\n\u6BCF\u7576\u591C\u665A\u964D\u81E8\uFF0C\u6211\u7684\u773C\u524D\u5C31\u6703\r\n\u6D6E\u73FE\u7576\u6642\u7684\u60C5\u666F\uFF0C\u8B93\u6211\u986B\u6296\u4E0D\u5DF2\u3002\r\n\u62DC\u8A17\u4E86\uFF0C\u8ACB\u6253\u5012\u90A3\u500B\u50A2\u4F19\u3002",
