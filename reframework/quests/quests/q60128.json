      {
        "Language": "RUS",
        "Name": "\u041B\u0443\u0447\u0448\u0438\u0439 \u0434\u0440\u0443\u0433 Blue Bomber",
        "Client": "\u041F\u043E\u0447\u0442\u0430\u043B\u044C\u043E\u043D \u0421\u044D\u043D\u0440\u0438",
        "Description": "\u0423 \u043C\u044F\u0443\u043D\u044F \u0435\u0441\u0442\u044C \u0434\u043B\u044F \u0442\u0435\u0431\u044F \u043E\u0441\u043E\u0431\u043E\u0435\r\n\u0437\u0430\u0434\u0430\u043D\u0438\u0435 \u0438\u0437 \u0441\u0435\u0440\u0438\u0438 Mega Man! \u0422\u0443\u0442\r\n\u0436\u0438\u0432\u0435\u0442 \u0417\u0438\u043D\u043E\u0433\u0440, \u043E\u043D \u0445\u043E\u0442\u044C \u0438\r\n\u043C\u0435\u043B\u043A\u0438\u0439, \u043D\u043E \u0441\u0438\u043B\u044C\u043D\u043E \u043C\u0435\u043D\u044F \u0434\u043E\u0441\u0442\u0430\u043B.\r\n\u0420\u0430\u0437\u0434\u0435\u043B\u0430\u0439\u0441\u044F \u0441 \u043D\u0438\u043C \u0438 \u044F \u0434\u0430\u043C \u0442\u0435\u0431\u0435\r\n\u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B \u0434\u043B\u044F \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u0432\u0435\u0440\u043D\u043E\u0433\u043E\r\n\u0441\u043F\u0443\u0442\u043D\u0438\u043A\u0430 Mega Man!",
        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0417\u0438\u043D\u043E\u0433\u0440\u0430",
        "Fail": "\u0421\u0447\u0435\u0442\u0447\u0438\u043A \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0434\u043E\u0445\u043E\u0434\u0438\u0442 \u0434\u043E 0\r\n\u0438\u043B\u0438 \u0438\u0441\u0442\u0435\u043A\u0430\u0435\u0442 \u0432\u0440\u0435\u043C\u044F"
