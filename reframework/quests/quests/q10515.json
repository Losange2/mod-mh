        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0411\u0430\u0437\u0430\u0440\u0438\u043E\u0441\u0430 \u0438 \u0412\u043E\u043B\u044C\u0432\u0438\u0434\u043E\u043D\u0430",
