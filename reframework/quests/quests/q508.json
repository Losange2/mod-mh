      {
        "Language": "RUS",
        "Name": "\u0421\u0435\u043A\u0440\u0435\u0442\u043D\u044B\u0439 \u0438\u043D\u0433\u0440\u0435\u0434\u0438\u0435\u043D\u0442",
        "Client": "\u041F\u043E\u0432\u0430\u0440 \u0419\u043E\u043C\u043E\u0433\u0438",
        "Description": "\u042F \u0445\u043E\u0447\u0443 \u0434\u0435\u043B\u0430\u0442\u044C \u043D\u043E\u0432\u044B\u0435 \u0434\u0430\u043D\u0433\u043E,\r\n\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0431\u0443\u0434\u0443\u0442 \u043F\u0440\u0438\u0434\u0430\u0432\u0430\u0442\u044C \u0441\u0438\u043B \u043D\u0435\r\n\u0445\u0443\u0436\u0435 \u0445\u043E\u0440\u043E\u0448\u0435\u0433\u043E \u0441\u043D\u0430. \u041D\u043E \u0434\u043B\u044F\r\n\u044D\u0442\u043E\u0433\u043E \u043D\u0430\u0434\u043E \u043F\u043E\u0439\u043C\u0430\u0442\u044C\r\n\u003CCOL RED\u003E\u0421\u043E\u043C\u043D\u0430\u043A\u0430\u043D\u0442\u0430\u003C/COL\u003E, \u0438\u0437 \u0435\u0433\u043E \u043F\u0435\u0441\u043D\u0438\r\n\u044F \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044E \u0440\u0435\u0446\u0435\u043F\u0442! \u041F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430!",
        "Target": "\u041F\u043E\u0439\u043C\u0430\u0442\u044C \u0421\u043E\u043C\u043D\u0430\u043A\u0430\u043D\u0442\u0430",
        "Fail": "\u0421\u0447\u0435\u0442\u0447\u0438\u043A \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0434\u043E\u0445\u043E\u0434\u0438\u0442 \u0434\u043E 0,\r\n\u0438\u0441\u0442\u0435\u043A\u0430\u0435\u0442 \u0432\u0440\u0435\u043C\u044F, \u0443\u043C\u0438\u0440\u0430\u0435\u0442 \u0446\u0435\u043B\u044C"
