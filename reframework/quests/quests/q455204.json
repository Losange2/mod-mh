  "QuestText": {
    "QuestInfo": [
      {
        "Language": "JPN",
        "Name": "\u30D5\u30EB\u30D5\u30EB\u306E\u8ABF\u67FB",
        "Client": "\u738B\u56FD\u9A0E\u58EB\u30D5\u30A3\u30AA\u30EC\u30FC\u30CD",
        "Description": "\u003CPL\u003E\u3001\u738B\u56FD\u304B\u3089\u306E\r\n\u8ABF\u67FB\u4F9D\u983C\u304C\u5C4A\u3044\u305F\u305E\u3002\r\n\u306A\u308B\u3079\u304F\u591A\u89D2\u7684\u306A\u8ABF\u67FB\u7D50\u679C\u304C\r\n\u6C42\u3081\u3089\u308C\u308B\u305F\u3081\u3001\u76DF\u52C7\u3068\u5171\u306B\r\n\u30AF\u30A8\u30B9\u30C8\u306B\u6311\u3093\u3067\u3082\u3089\u3044\u305F\u3044\u3002\r\n\u8CB4\u6BBF\u3068\u76DF\u52C7\u306E\u5065\u95D8\u3092\u7948\u308B\u3002\r\n\u304F\u308C\u3050\u308C\u3082\u6CB9\u65AD\u306A\u304D\u3088\u3046\u306B\u306A\u3002",
        "Target": "\u30D5\u30EB\u30D5\u30EB\uFF11\u982D\u306E\u72E9\u731F",
