        "Language": "ARA",
        "Name": "\u0627\u0644\u0641\u0627\u0631\u0633 \u0627\u0644\u0623\u0628\u064A\u0636 \u0641\u064A \u0645\u0648\u0627\u062C\u0647\u0629 \u0627\u0644\u0635\u064A\u0651\u0627\u062F",
