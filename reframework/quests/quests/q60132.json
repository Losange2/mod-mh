      {
        "Language": "RUS",
        "Name": "\u0417\u0430\u043F\u0443\u0442\u0430\u043D\u043D\u043E\u0435 \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435",
        "Client": "\u041A\u0440\u0430\u0441\u0438\u0432. \u043E\u0445\u043E\u0442\u043D\u0438\u043A \u0437\u0430 \u0441\u043E\u043A\u0440\u043E\u0432.",
