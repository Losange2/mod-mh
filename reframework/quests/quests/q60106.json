        "Language": "JPN",
        "Name": "\u79F0\u53F7\u30FB\u30B7\u30CE\u30D3\u306E\u5FC3",
        "Client": "\u91CC\u9577\u30D5\u30B2\u30F3",
        "Description": "\u003CPL\u003E\u3088\uFF01\r\n\u95D8\u6280\u5834\u306B\u3066\u3001\u75BE\u304D\u3053\u3068\u98A8\u306E\u5982\u304D\r\n\u30E2\u30F3\u30B9\u30BF\u30FC\u305F\u3061\u304C\u96C6\u3044\u3001\u4ECA\u307E\u3055\u306B\r\n\u9802\u70B9\u3092\u6C7A\u3081\u3088\u3046\u3068\u3057\u3066\u3044\u308B\uFF01\u3000\r\n\u3057\u304B\u3057\u30AA\u30DE\u30A8\u306A\u3089\u3070\u305D\u306E\uFF13\u982D\u3092\u3082\r\n\u51CC\u3050\u3067\u3042\u308D\u3046\uFF01\u3000\u9054\u6210\u3057\u305F\u6681\u306B\u306F\r\n\u65B0\u305F\u306A\u79F0\u53F7\u3092\u6388\u3051\u308B\u305E\uFF01",
