      {
        "Language": "RUS",
        "Name": "\u0421\u0435\u0440\u0434\u0446\u0435 \u043D\u0438\u043D\u0434\u0437\u044F",
        "Client": "\u0421\u0442\u0430\u0440\u0435\u0439\u0448\u0438\u043D\u0430 \u0424\u0443\u0433\u044D\u043D",
        "Description": "\u042D\u0439, \u0412\u044B\u0441\u043A\u043E\u0447\u043A\u0430! \u041D\u0430\u043C \u0434\u0430\u043B\u0438 \u0435\u0449\u0435\r\n\u043E\u0434\u043D\u0443 \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0443\u044E \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0443 \u043D\u0430\r\n\u0410\u0440\u0435\u043D\u0435, \u043E\u043D\u0430 \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043D\u0430 \u0434\u043B\u044F\r\n\u043B\u0443\u0447\u0448\u0438\u0445 \u0438\u0437 \u043B\u0443\u0447\u0448\u0438\u0445. \u041F\u0440\u043E\u0439\u0434\u0438 \u0435\u0435 \u2014\r\n\u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u0448\u044C \u043D\u043E\u0432\u044B\u0439 \u0442\u0438\u0442\u0443\u043B. \u042D\u0442\u0438\r\n\u043C\u043E\u043D\u0441\u0442\u0440\u044B \u0434\u0443\u043C\u0430\u044E\u0442, \u0447\u0442\u043E \u043E\u043D\u0438\r\n\u043A\u0440\u0443\u0442\u044B\u0435, \u043D\u043E \u044F \u0441\u0442\u0430\u0432\u043B\u044E \u043D\u0430 \u0442\u0435\u0431\u044F!",
        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0432\u0441\u0435\u0445 \u043E\u0442\u043C\u0435\u0447\u0435\u043D\u043D\u044B\u0445 \u043C\u043E\u043D\u0441\u0442\u0440\u043E\u0432",
