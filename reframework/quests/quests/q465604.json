  "QuestText": {
    "QuestInfo": [
      {
        "Language": "JPN",
        "Name": "\u6012\u308A\u306E\u5FF5\u306F\u6D88\u3048\u308B\u3053\u3068\u7121\u304F",
        "Client": "\u63D0\u7763\u30AC\u30EC\u30A2\u30B9",
        "Description": "\u2026\u2026\u6EB6\u5CA9\u6D1E\u3067\u30E9\u30FC\u30B8\u30E3\u30F3\u306E\u59FF\u304C\r\n\u76EE\u6483\u3055\u308C\u3066\u3044\u308B\u3002\u5831\u544A\u306B\u3088\u308B\u3068\u3001\r\n\u305D\u308C\u306F\u7279\u7570\u306A\u56FA\u4F53\u3067\u3042\u308A\u3001\u6975\u3081\u3066\r\n\u51F6\u66B4\u3068\u306E\u3053\u3068\u3002\r\n\u9A0E\u58EB\u56E3\u306E\u7CBE\u92ED\u305F\u3061\u3067\u3082\u624B\u306B\r\n\u4F59\u308B\u3053\u3068\u304C\u4E88\u60F3\u3055\u308C\u308B\u3002\u8CB4\u6BBF\u3068\r\n\u79C1\u3068\u3067\u5BFE\u51E6\u306B\u3042\u305F\u308A\u305F\u3044\u3002",
        "Target": "\u6FC0\u6602\u3057\u305F\u30E9\u30FC\u30B8\u30E3\u30F3\uFF11\u982D\u306E\u72E9\u731F",
        "Fail": "\u5831\u916C\u91D1\u30BC\u30ED\r\n\u30BF\u30A4\u30E0\u30A2\u30C3\u30D7"
      },
      {
        "Language": "ENG",
        "Name": "Rage That Never Dies",
        "Client": "Admiral Galleus",
        "Description": "A Rajang variant has been\r\nsighted in the Lava Caverns.\r\nWe cannot let such a violent\r\nbeast go unchecked. I don\u0027t\r\nhave to remind you of the\r\nseverity of this situation. Your\r\norders are clear. Get it done.",
        "Target": "Hunt a Furious Rajang",
        "Fail": "Reward hits 0, or time expires"
      },
      {
        "Language": "FRE",
        "Name": "La rage immortelle",
        "Client": "Amiral Galleus",
        "Description": "Un Rajang a \u00E9t\u00E9 aper\u00E7u dans\r\nles Cavernes de lave.\r\nApparemment, ce serait une\r\nesp\u00E8ce plus f\u00E9roce... en tout\r\ncas, bien trop pour \u00EAtre\r\nvaincue par nos chevaliers. Je\r\ncompte sur toi, chasse-le.",
        "Target": "Chasser un Rajang orage",
        "Fail": "Prime \u00E0 0/Temps expir\u00E9"
      },
      {
        "Language": "ITA",
        "Name": "Rabbia inesauribile",
        "Client": "Ammiraglio Galleus",
        "Description": "Un Rajang \u00E8 stato avvistato\r\nalle Caverne laviche. Pare sia\r\nun esemplare di singolare ira,\r\ntroppo da gestire perfino per\r\ni nostri cavalieri d\u0027\u00E9lite.\r\nSpero mi aiuterai a cacciarlo.",
        "Target": "Caccia un Rajang furioso",
        "Fail": "Premio a zero o tempo scaduto"
      },
      {
        "Language": "GER",
        "Name": "Unendliche Wut",
        "Client": "Galleus",
        "Description": "In den Lavah\u00F6hlen wurde eine\r\nRajang-Variante gesichtet. So\r\neine extrem aggressive Bestie\r\nk\u00F6nnen wir nicht einfach dort\r\nlassen. Deine Befehle sind\r\nklar, also kl\u00E4re die Lage!",
        "Target": "Erjage einen Zornigen Rajang.",
        "Fail": "Belohnung auf 0 oder Zeit\r\nl\u00E4uft ab."
      },
      {
        "Language": "SPA",
        "Name": "La c\u00F3lera nunca muere",
        "Client": "Almirante Galleus",
        "Description": "Se ha avistado una variante de\r\nRajang en las Grutas de lava.\r\nNo podemos dejar campar a una\r\nbestia tan agresiva. No tengo ni\r\nque explicarte lo peligrosa que\r\nes esta situaci\u00F3n. Tus \u00F3rdenes\r\nest\u00E1n claras. Adelante.",
        "Target": "Caza un Rajang Rabioso",
        "Fail": "La recompensa cae a 0\r\no se acaba el tiempo"
      },
      {
        "Language": "RUS",
        "Name": "\u041D\u0435\u0443\u043A\u0440\u043E\u0442\u0438\u043C\u0430\u044F \u044F\u0440\u043E\u0441\u0442\u044C",
