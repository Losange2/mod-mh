        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0412\u0437\u0431\u0435\u0448\u0435\u043D\u043D\u043E\u0433\u043E \u0440\u0430\u044F\u043D\u0433\u0430",
