      {
        "Language": "RUS",
        "Name": "\u041A\u043B\u0430\u0441\u0441 \u0432\u043B\u0430\u0434\u0435\u043D\u0438\u044F \u043A\u043E\u043F\u044C\u0435\u043C",
        "Client": "\u041C\u0430\u0441\u0442\u0435\u0440 \u0423\u0446\u0443\u0441\u0438",
        "Description": "\u041D\u0443 \u0447\u0442\u043E, \u0430\u0441, \u043F\u043E\u0440\u0430 \u0443\u0447\u0438\u0442\u044C\u0441\u044F!\r\n\u0420\u044B\u0446\u0430\u0440\u044C \u043D\u043E\u0441\u0438\u0442 \u0441\u0432\u043E\u0435 \u043A\u043E\u043F\u044C\u0435,\r\n\u0447\u0442\u043E\u0431\u044B \u0437\u0430\u0449\u0438\u0449\u0430\u0442\u044C \u0441\u043B\u0430\u0431\u044B\u0445,\r\n\u043A\u0430\u043A \u003CCOL RED\u003E\u0420\u0430\u0442\u0438\u0430\u043D\u0430\u003C/COL\u003E \u0437\u0430\u0449\u0438\u0449\u0430\u0435\u0442\r\n\u0441\u0432\u043E\u0439 \u043C\u043E\u043B\u043E\u0434\u043D\u044F\u043A. \u041F\u043E\u0439\u043C\u0430\u0439\r\n\u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0443 \u2014 \u0440\u0430\u0437\u0436\u0438\u0432\u0435\u0448\u044C\u0441\u044F \u043D\u043E\u0432\u044B\u043C\u0438\r\n\u043D\u0430\u0432\u044B\u043A\u0430\u043C\u0438 \u0434\u043B\u044F \u043A\u043E\u043F\u044C\u044F!",
        "Target": "\u041F\u043E\u0439\u043C\u0430\u0442\u044C \u0420\u0430\u0442\u0438\u0430\u043D\u0443",
        "Fail": "\u0421\u0447\u0435\u0442\u0447\u0438\u043A \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0434\u043E\u0445\u043E\u0434\u0438\u0442 \u0434\u043E 0,\r\n\u0438\u0441\u0442\u0435\u043A\u0430\u0435\u0442 \u0432\u0440\u0435\u043C\u044F, \u0443\u043C\u0438\u0440\u0430\u0435\u0442 \u0446\u0435\u043B\u044C"
