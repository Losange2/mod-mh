      {
        "Language": "RUS",
        "Name": "\u041A\u0440\u0435\u0449\u0435\u043D\u044C\u0435 \u043E\u0433\u043D\u0435\u043C",
        "Client": "\u041D\u0435\u0432\u043E\u0437\u043C\u0443\u0442\u0438\u043C\u044B\u0439 \u0431\u0438\u043E\u043B\u043E\u0433",
        "Description": "\u042F, \u043A\u043E\u0433\u0434\u0430 \u0432\u044B\u0445\u043E\u0436\u0443 \u0432 \u043F\u043E\u0445\u043E\u0434, \u043D\u0435\r\n\u043E\u0431\u0440\u0430\u0449\u0430\u044E \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u044F \u043D\u0430 \u0434\u0440\u0430\u043A\u0438\r\n\u043C\u043E\u043D\u0441\u0442\u0440\u043E\u0432 \u2014 \u043A \u0442\u043E\u043C\u0443 \u0436\u0435, \u0443 \u043C\u0435\u043D\u044F\r\n\u0435\u0441\u0442\u044C \u0437\u0430\u0449\u0438\u0442\u043D\u044B\u0439 \u043F\u043B\u0430\u0449. \u041D\u043E \u0441\u0435\u0439\u0447\u0430\u0441\r\n\u043D\u0435 \u043E\u0431\u0440\u0430\u0449\u0430\u0442\u044C \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u044F \u0442\u0440\u0443\u0434\u043D\u043E,\r\n\u043B\u0435\u0441 \u0438 \u0442\u043E\u043D\u0435\u0442 \u0438 \u0433\u043E\u0440\u0438\u0442\r\n\u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E.",
        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0432\u0441\u0435\u0445 \u043E\u0442\u043C\u0435\u0447\u0435\u043D\u043D\u044B\u0445 \u043C\u043E\u043D\u0441\u0442\u0440\u043E\u0432",
