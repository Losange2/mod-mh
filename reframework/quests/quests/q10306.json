      {
        "Language": "JPN",
        "Name": "\u6CE5\u3001\u3069\u308D\u3001\u30AA\u30ED\u30DF\u30C9\u30ED",
        "Client": "\u614C\u3066\u308B\u8FB2\u5BB6\u306E\u7537\u6027",
        "Description": "\u5927\u5909\u3060\u3041\u3001\u30CF\u30F3\u30BF\u30FC\u3055\u3093\u3002\r\n\u30AA\u30ED\u30DF\u30C9\u30ED\u304C\u73FE\u308C\u3061\u307E\u3063\u305F\u3088\uFF01\r\n\u3042\u3044\u3064\u306F\u5730\u9762\u3092\u6EB6\u304B\u3057\u305F\u308A\u3057\u3066\r\n\u3081\u3061\u3083\u304F\u3061\u3083\u306B\u66B4\u308C\u3063\u304B\u3089\u3001\r\n\u305B\u3063\u304B\u304F\u304A\u3089\u9054\u304C\u8015\u3057\u305F\u571F\u5730\u304C\r\n\u30C0\u30E1\u306B\u306A\u3063\u3061\u307E\u3046\u3088\u3049\u2026\u3002\r\n\u65E9\u3047\u3068\u3053\u3001\u72E9\u731F\u3092\u304A\u983C\u307F\u3057\u307E\u3059\u3002",
