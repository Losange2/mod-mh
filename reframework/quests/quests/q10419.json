      {
        "Language": "RUS",
        "Name": "\u0421\u0438\u043D\u0438\u0439, \u043A\u0440\u0443\u0433\u043B\u044B\u0439, \u0441\u0438\u043C\u043F\u0430\u0442\u0438\u0447\u043D\u044B\u0439",
        "Client": "\u042D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u044B\u0439 \u0443\u0447\u0435\u043D\u044B\u0439",
        "Description": "\u042D\u0439! \u0421\u043A\u0430\u0436\u0438-\u043A\u0430, \u0440\u0430\u0437\u0432\u0435 \u0410\u0440\u0437\u0443\u0440\u043E\u0441\u044B\r\n\u043D\u0435 \u043C\u0438\u043B\u0430\u0448\u043A\u0438? \u041F\u0443\u0448\u0438\u0441\u0442\u044B\u0439 \u0441\u0438\u043D\u0438\u0439\r\n\u043C\u0435\u0445, \u043C\u044F\u0433\u043A\u043E\u0435 \u043F\u0443\u0437\u0438\u043A\u043E \u2014\r\n\u0432\u043E\u0442 \u0431\u044B \u0442\u0430\u043A\u043E\u0433\u043E \u043E\u0431\u043D\u044F\u0442\u044C! \u041C\u043E\u0436\u0435\u0448\u044C\r\n\u043F\u043E\u0439\u043C\u0430\u0442\u044C \u0434\u043B\u044F \u043C\u0435\u043D\u044F \u0442\u0430\u043A\u043E\u0433\u043E\r\n\u043A\u0440\u0430\u0441\u0430\u0432\u0446\u0430? \u0427\u0442\u043E \u0437\u043D\u0430\u0447\u0438\u0442,\r\n\u0022\u0435\u0441\u043B\u0438 \u043F\u043E\u043E\u0431\u0435\u0449\u0430\u044E \u043D\u0435 \u043E\u0431\u043D\u0438\u043C\u0430\u0442\u044C\u0022?",
        "Target": "\u041F\u043E\u0439\u043C\u0430\u0442\u044C \u0410\u0440\u0437\u0443\u0440\u043E\u0441\u0430",
        "Fail": "\u0421\u0447\u0435\u0442\u0447\u0438\u043A \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0434\u043E\u0445\u043E\u0434\u0438\u0442 \u0434\u043E 0,\r\n\u0438\u0441\u0442\u0435\u043A\u0430\u0435\u0442 \u0432\u0440\u0435\u043C\u044F, \u0443\u043C\u0438\u0440\u0430\u0435\u0442 \u0446\u0435\u043B\u044C"
