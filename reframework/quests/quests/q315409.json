        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0411\u0430\u0440\u0438\u043E\u0442\u0430 \u0438 \u041C\u0430\u0433\u043D\u0430\u043C\u0430\u043B\u043E",
