      },
      {
        "Language": "ENG",
        "Name": "Howling Moon",
        "Client": "Dame Fiorayne",
        "Description": "We have received reports of a\r\nLunagaron going berserk in the\r\nhighlands of the Citadel. Its\r\nattacks and violent behavior\r\nare causing other monsters to\r\ngo berserk, as well. Something\r\nmust be done and quickly!",
        "Target": "Hunt a Lunagaron",
        "Fail": "Reward hits 0, or time expires"
      },
      {
        "Language": "FRE",
        "Name": "Lune hurlante",
        "Client": "Dame Fiorayne",
        "Description": "Des Lunagaron sont en train\r\nde saccager le Plateau\r\nforteresse. Si \u00E7a continue,\r\nils risquent d\u0027ab\u00EEmer toute\r\nla zone alentour. Tu sais\r\nce qu\u0027il te reste \u00E0 faire...",
        "Target": "Chasser un Lunagaron",
        "Fail": "Prime \u00E0 0/Temps expir\u00E9"
      },
      {
        "Language": "ITA",
        "Name": "Luna ululante",
        "Client": "Dama Fiorayne",
        "Description": "Abbiamo ricevuto segnalazioni\r\ndi un Lunagaron scatenato\r\nall\u0027altopiano della fortezza.\r\nSe continua, potrebbe causare\r\ndanni nelle aree circostanti.\r\nTu sei la persona giusta per\r\naffrontare questa missione.",
        "Target": "Caccia un Lunagaron",
        "Fail": "Premio a zero o tempo scaduto"
      },
      {
        "Language": "GER",
        "Name": "Heulender Mond",
        "Client": "Fiorayne",
        "Description": "Wir haben Berichte erhalten,\r\ndass auf dem Zitadellenplateau\r\nein Lunagaron tobt. Sein wildes\r\nVerhalten k\u00F6nnte andere Bestien\r\ndazu inspirieren, ebenfalls\r\ndurchzudrehen. Bereite dem\r\nTreiben also schnell ein Ende!",
        "Target": "Erjage einen Lunagaron.",
        "Fail": "Belohnung auf 0 oder Zeit\r\nl\u00E4uft ab."
      },
      {
        "Language": "SPA",
        "Name": "Luna aulladora",
        "Client": "Fiorayne",
        "Description": "Nos informan de que hay un\r\nLunagaron causando estragos\r\nen los alrededores del Basti\u00F3n.\r\nSi sigue as\u00ED, volver\u00E1 agresivos\r\na otros monstruos, tambi\u00E9n.\r\n\u00A1Hay que hacer algo enseguida!",
        "Target": "Caza un Lunagaron",
        "Fail": "La recompensa cae a 0\r\no se acaba el tiempo"
      },
