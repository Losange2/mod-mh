      {
        "Language": "RUS",
        "Name": "\u041A\u0440\u0443\u0447\u0443-\u0432\u0435\u0440\u0447\u0443",
        "Client": "\u0421\u044B\u043D \u043A\u0443\u0437\u043D\u0435\u0446\u0430",
        "Description": "\u041A\u0430\u043A\u0438\u0435 \u043A\u0440\u0443\u0442\u044B\u0435 \u0440\u043E\u0433\u0430! \u041A\u0430\u043A \u0440\u0430\u0437 \u0434\u043B\u044F\r\n\u043C\u043E\u043D\u0441\u0442\u0440\u0430 \u043F\u043E\u0434 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435\u043C \u0414\u0438\u0430\u0431\u043B\u043E\u0441!\r\n\u0412\u043E\u0442 \u0431\u044B \u043C\u043D\u0435 \u0442\u0430\u043A\u0438\u0435, \u044F \u0431\u044B \u0438\u0437\r\n\u043D\u0438\u0445 \u0441\u0432\u043E\u044E \u0432\u044B\u0432\u0435\u0441\u043A\u0443 \u0441\u0434\u0435\u043B\u0430\u043B. \u0422\u043E-\u0442\u043E\r\n\u0431\u044B \u043A\u043B\u0438\u0435\u043D\u0442\u044B \u043F\u043E\u0448\u043B\u0438!",
        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0414\u0438\u0430\u0431\u043B\u043E\u0441\u0430",
        "Fail": "\u0421\u0447\u0435\u0442\u0447\u0438\u043A \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0434\u043E\u0445\u043E\u0434\u0438\u0442 \u0434\u043E 0\r\n\u0438\u043B\u0438 \u0438\u0441\u0442\u0435\u043A\u0430\u0435\u0442 \u0432\u0440\u0435\u043C\u044F"
