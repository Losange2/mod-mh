      {
        "Language": "KOR",
        "Name": "\uCDA4\uCD94\uB294 \uAC83\uC740 \uBAA8\uB798\uC778\uAC00 \uCE7C\uB0A0\uC778\uAC00",
        "Client": "\uC54C\uB85C \uAD50\uAD00",
