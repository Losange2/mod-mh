        "Language": "JPN",
        "Name": "\u7406\u89E3\u305B\u3088\uFF01\u3000\u72E9\u731F\u7B1B\u306E\u578B",
        "Client": "\u30A6\u30C4\u30B7\u6559\u5B98",
        "Description": "\u3084\u3042\u3001\u6211\u304C\u611B\u5F1F\u5B50\u3088\uFF01\r\n\u4ECA\u306A\u304A\u6B8B\u308B\u795E\u3005\u306E\u606F\u5439\u306B\r\n\u8033\u3092\u50BE\u3051\u306A\u304C\u3089\u3001\u8972\u3044\u304B\u304B\u308B\r\n\u30E2\u30F3\u30B9\u30BF\u30FC\u3092\u6B21\u3005\u306B\u9000\u3051\u308B\u3093\u3060\uFF01\r\n\u81EA\u7136\u304C\u594F\u3067\u308B\u97F3\u8272\u3068\u5171\u306B\u72E9\u731F\u3092\r\n\u3059\u308C\u3070\u3001\u72E9\u731F\u7B1B\u3067\u306E\u7ACB\u3061\u56DE\u308A\u3092\r\n\u5E83\u3052\u308B\u30B3\u30C4\u304C\u3064\u304B\u3081\u308B\u306F\u305A\u3060\u305E\uFF01",
