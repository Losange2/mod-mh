        "Name": "\u0417\u0430\u0440\u044F \u041A\u0435\u0441\u0442\u043E\u0434\u043E\u043D\u043E\u0432",
        "Client": "\u0421\u043A\u043E\u043D\u0444\u0443\u0436\u0435\u043D\u043D\u044B\u0439 \u0447\u0435\u043B\u043E\u0432\u0435\u043A",
