        "Fail": "La recompensa cae a 0\r\no se acaba el tiempo"
      },
      {
        "Language": "RUS",
        "Name": "\u041F\u043E\u043C\u0435\u0445\u0430 \u043F\u043B\u0430\u043D\u0430\u043C",
        "Client": "\u041A\u0443\u0437\u043D\u0435\u0446 \u0425\u0430\u043C\u043E\u043D",
        "Description": "\u0427\u0442\u043E\u0431\u044B \u043E\u0442\u0434\u0435\u043B\u0438\u0442\u044C \u041C\u0430\u0433\u043D\u0430\u043C\u0430\u043B\u043E \u043E\u0442\r\n\u0411\u0443\u0439\u0441\u0442\u0432\u0430, \u043C\u043D\u0435 \u043D\u0443\u0436\u043D\u043E \u0434\u043E\u0434\u0435\u043B\u0430\u0442\u044C\r\n\u0441\u0432\u043E\u0435 \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E. \u0414\u043B\u044F \u044D\u0442\u043E\u0433\u043E\r\n\u043C\u043D\u0435 \u043D\u0443\u0436\u043D\u044B \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B \u0438\u0437\r\n\u0411\u0438\u0441\u044F\u0442\u044D\u043D\u0430. \u0411\u0438\u0441\u044F\u0442\u044D\u043D\u0430 \u043D\u0435\u0434\u0430\u0432\u043D\u043E\r\n\u0432\u0438\u0434\u0435\u043B\u0438 \u0432 \u0420\u0443\u0438\u043D\u0430\u0445 \u0441\u0432\u044F\u0442\u0438\u043B\u0438\u0449\u0430.\r\n\u0421\u0440\u043E\u0447\u043D\u043E \u0438\u0434\u0438 \u0442\u0443\u0434\u0430!",
        "Target": "\u0412\u044B\u0441\u043B\u0435\u0434\u0438\u0442\u044C \u0411\u0438\u0441\u044F\u0442\u044D\u043D\u0430",
        "Fail": "\u0421\u0447\u0435\u0442\u0447\u0438\u043A \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0434\u043E\u0445\u043E\u0434\u0438\u0442 \u0434\u043E 0\r\n\u0438\u043B\u0438 \u0438\u0441\u0442\u0435\u043A\u0430\u0435\u0442 \u0432\u0440\u0435\u043C\u044F"
