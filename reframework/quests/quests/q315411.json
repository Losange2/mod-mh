      {
        "Language": "JPN",
        "Name": "\u5927\u793E\u8DE1\u306E\u8352\u304F\u308C\u30C8\u30EA\u30AA",
        "Client": "\u81EA\u7136\u3092\u898B\u5B88\u308B\u8001\u4EBA",
        "Description": "\u6C17\u306E\u305B\u3044\u304B\u3082\u3057\u308C\u306C\u304C\u2026\u6700\u8FD1\u3001\r\n\u5927\u793E\u8DE1\u306B\u4F4F\u307E\u3046\u30E2\u30F3\u30B9\u30BF\u30FC\u9054\u304C\r\n\u602F\u3048\u3066\u3044\u308B\u3088\u3046\u306B\u898B\u3048\u308B\u306E\u3058\u3083\u3002\r\n\u30C4\u30C6\u3092\u4F7F\u3063\u3066\u3001\u5C11\u3057\u8ABF\u3079\u305F\u6240\u2026\r\n\uFF13\u982D\u306E\u30E2\u30F3\u30B9\u30BF\u30FC\u304C\u66B4\u308C\u3066\u304A\u308B\u306E\r\n\u304C\u6050\u3089\u304F\u306E\u539F\u56E0\u3067\u306A\u2026\u3002\u5C11\u3057\u3070\u304B\r\n\u3057\u3001\u898B\u3066\u304D\u3066\u306F\u304F\u308C\u306C\u304B\uFF1F",
        "Target": "\u5168\u3066\u306E\u30BF\u30FC\u30B2\u30C3\u30C8\u306E\u72E9\u731F",
