      {
        "Language": "KOR",
        "Name": "\uB208\uCC98\uB7FC \uBE5B\uB098\uB294 \uB4DC\uB808\uC2A4 \uC81C\uC791",
        "Client": "\uAC1C\uBC29\uC801\uC778 \uC637\uAC00\uAC8C \uC810\uC7A5",
        "Description": "\uC544\uB984\uB2E4\uC6B4 \uCC9C\uACFC \uD488\uC9C8 \uC88B\uC740 \uBC14\uB298.\r\n\uB4DC\uB808\uC2A4\uB97C \uB9CC\uB4E4 \uC900\uBE44\uB294 \uB05D\uB0AC\uC5B4.\r\n\uC774\uC81C \uB514\uC790\uC778\uB9CC \uC815\uD558\uBA74 \uB3FC.\r\n\uC77C\uB801\uC774\uB294 \uADC0\uD654\uC640 \uB208\uC744 \uBC30\uACBD\uC73C\uB85C\r\n\uB178\uB798\uD558\uB294 \uBE59\uC778\uC5B4\uB8E1\uC744 \uADF8\uB9AC\uACE0 \r\n\uC2F6\uC5B4. \uD55C\uB7AD \uAD70\uB3C4\uAE4C\uC9C0\r\n\uB530\uB77C\uC640 \uC904 \uC0AC\uB78C\uC740 \uC5C6\uC73C\uB824\uB098?",
        "Target": "\uC774\uC18C\uB124\uBBF8\uCFE0\uB2C8 \uC544\uC885 1\uB9C8\uB9AC\uC640\r\n\uB9C8\uAC00\uC774\uB9C8\uAC00\uB3C4 1\uB9C8\uB9AC \uC0AC\uB0E5",
