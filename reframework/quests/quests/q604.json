      {
        "Language": "ENG",
        "Name": "Abominable Snow-beast",
        "Client": "Tundra-dwelling Mother",
        "Description": "A monster in the Frost Islands\r\nhas been roaring after dark.\r\nThe cries have terrified my\r\nchild, who now refuses to go\r\nto the toilet alone at night!\r\nPlease, help us if you can!",
        "Target": "Hunt a Goss Harag",
        "Fail": "Reward hits 0, or time expires"
